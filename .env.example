# ── Provider — any OpenAI-compatible API ─────────────────────────────────────
#
# Examples:
#   NVIDIA NIM (free tier):   https://integrate.api.nvidia.com/v1
#   DeepSeek:                 https://api.deepseek.com/v1
#   Groq:                     https://api.groq.com/openai/v1
#   OpenRouter (200+ models): https://openrouter.ai/api/v1
#   Ollama (local):           http://localhost:11434/v1
#   LM Studio (local):        http://localhost:1234/v1
#
PROVIDER_BASE_URL=https://integrate.api.nvidia.com/v1
PROVIDER_API_KEY=your-api-key-here

# Model name as the provider expects it
# NIM:        meta/llama-3.3-70b-instruct
# DeepSeek:   deepseek-chat
# Groq:       llama-3.3-70b-versatile
# OpenRouter: meta-llama/llama-3.3-70b-instruct
PROVIDER_MODEL=meta/llama-3.3-70b-instruct

PROVIDER_MAX_TOKENS=32768
PROVIDER_TEMPERATURE=1.0
PROVIDER_TOP_P=1.0

# ── Server ───────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8082
LOG_FILE=proxy.log

# ── Request optimizations (reduce provider quota usage) ──────────────────────
SKIP_QUOTA_PROBES=true
SKIP_TITLE_GENERATION=true
SKIP_SUGGESTION_MODE=true
MOCK_PREFIX_DETECTION=true
MOCK_FILEPATH_EXTRACTION=true

# ── Telegram (optional) ──────────────────────────────────────────────────────
# Uncomment and fill in to enable the Telegram bot.
# Create a bot via @BotFather, find your user ID via @userinfobot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_ID=

# ── CLI sessions (Telegram integration) ──────────────────────────────────────
CLAUDE_WORKSPACE=./workspace
MAX_CLI_SESSIONS=5
